{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with display name, bio, profile photo, and onboarding status.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique Firebase Auth user UID." },
        "displayName": { "type": "string", "description": "User's public name in Myanmar language or custom text." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "bio": { "type": "string", "description": "Short bio or intro." },
        "onboarded": { "type": "boolean", "description": "Whether the user completed onboarding." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Profile creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Profile update timestamp." },
        "lastActiveAt": { "type": "integer", "description": "Unix timestamp in milliseconds of user last activity." },
        "notificationSettings": {
          "type": "object",
          "description": "Notification toggles.",
          "properties": {
            "newPost": { "type": "boolean" },
            "newReaction": { "type": "boolean" },
            "newComment": { "type": "boolean" },
            "newMessage": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "displayName", "onboarded"]
    },
    "Post": {
      "title": "Post",
      "description": "A text or photo post in the feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique post ID." },
        "authorId": { "type": "string", "description": "UID of the user who published the post." },
        "authorName": { "type": "string", "description": "Display name of the author when post was created." },
        "authorPhoto": { "type": "string", "description": "Profile photo of the author when post was created." },
        "text": { "type": "string", "description": "Text content of the post." },
        "photoURL": { "type": "string", "description": "Optional attached picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "likesCount": { "type": "integer" },
        "hahaCount": { "type": "integer" },
        "careCount": { "type": "integer" },
        "angryCount": { "type": "integer" },
        "commentsCount": { "type": "integer" },
        "hashtags": { "type": "array", "description": "Extracted hashtags from text." }
      },
      "required": ["id", "authorId", "authorName", "text", "createdAt"]
    },
    "Reaction": {
      "title": "Reaction",
      "description": "A single reaction from a user on a post.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "haha", "care", "angry"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "userId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment left on a post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "text", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A direct chat message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "audioUrl": { "type": "string", "description": "Base64 data URL encoded audio file." },
        "audioDuration": { "type": "number", "description": "Duration in seconds." },
        "createdAt": { "type": "string", "format": "date-time" },
        "reactions": { "type": "object", "description": "Key-value pair where key is user ID and value is the emoji react." }
      },
      "required": ["id", "senderId", "senderName", "receiverId", "createdAt"]
    },
    "Mute": {
      "title": "Muted User",
      "description": "Muted peer configuration.",
      "type": "object",
      "properties": {
        "muted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["muted", "createdAt"]
    },
    "Support": {
      "title": "Support Request",
      "description": "Anonymous support/feedback request submitted by a user.",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "createdAt"]
    }
  },
  "firestore": {
    "support/{supportId}": {
      "schema": "Support",
      "description": "Feedback and support tickets submitted by users."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings."
    },
    "users/{userId}/muted/{peerId}": {
      "schema": "Mute",
      "description": "Muted other users for chat settings."
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Shared posts feed."
    },
    "posts/{postId}/reactions/{userId}": {
      "schema": "Reaction",
      "description": "User reactions to specific posts."
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "User comments on specific posts."
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages inside a direct chat channel."
    }
  }
}
